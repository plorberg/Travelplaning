# Copy to .env.local and fill in. Server-only secrets must NOT be prefixed NEXT_PUBLIC_.

# Neon serverless Postgres connection string (free tier, no credit card).
# Example: postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Firebase client config — safe to expose (identifiers, not secrets).
# Firebase Console > Project settings > General > Your apps (Web app).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin service account — server-only secrets.
# Firebase Console > Project settings > Service accounts > Generate new private key.
# Paste the private key with literal \n escapes, wrapped in double quotes.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Currency provider: "frankfurter" (default, free ECB rates) or "mock" (offline dev).
CURRENCY_PROVIDER=frankfurter

# Only needed when the app is served through a reverse proxy / port-forward
# (e.g. a cloud preview URL), where Server Actions fail with
# "Invalid Server Actions request." Set to the host shown in the browser's
# address bar (no scheme, no path). Comma-separated; wildcards allowed.
# Examples: ALLOWED_SERVER_ACTION_ORIGINS=abc123.preview.example.dev
#           ALLOWED_SERVER_ACTION_ORIGINS=*.preview.example.dev
ALLOWED_SERVER_ACTION_ORIGINS=
